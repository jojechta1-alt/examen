rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos y registros históricos: lectura pública, escritura solo autenticada
    match /registros/{archivo} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Resultados de reconstrucción (si se llegan a guardar como archivo además del JSON en Firestore)
    match /reconstrucciones/{archivo} {
      allow read: if true;
      allow write: if false; // solo Cloud Functions, vía SDK admin
    }
  }
}
